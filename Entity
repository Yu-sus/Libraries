function Entity.RaycastFromCharacter(direction, ignoreList)
	if not rootPart then return nil end
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = ignoreList or {character}
	params.FilterType = Enum.RaycastFilterType.Blacklist
	return Workspace:Raycast(rootPart.Position, direction, params)
end

