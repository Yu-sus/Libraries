local partMap = {
	R15 = {
		Head = "Head",
		Torso = "UpperTorso",
		LowerTorso = "LowerTorso",
		LeftArm = "LeftUpperArm",
		RightArm = "RightUpperArm",
		LeftLeg = "LeftUpperLeg",
		RightLeg = "RightUpperLeg"
	},
	R6 = {
		Head = "Head",
		Torso = "Torso",
		LeftArm = "Left Arm",
		RightArm = "Right Arm",
		LeftLeg = "Left Leg",
		RightLeg = "Right Leg"
	}
}

local otherCharacters = setmetatable({}, {__mode = "v"})
local playerListeners = {}

local function trackPlayer(plr)
	if plr == player then return end
	local function onCharAdded(char)
		otherCharacters[plr] = char
	end
	local function onCharRemoving()
		otherCharacters[plr] = nil
	end
	playerListeners[plr] = {
		Added = plr.CharacterAdded:Connect(onCharAdded),
		Removing = plr.CharacterRemoving:Connect(onCharRemoving)
	}
	if plr.Character then
		onCharAdded(plr.Character)
	end
end

local function untrackPlayer(plr)
	local listeners = playerListeners[plr]
	if listeners then
		listeners.Added:Disconnect()
		listeners.Removing:Disconnect()
		playerListeners[plr] = nil
	end
	otherCharacters[plr] = nil
end

for _, plr in ipairs(Players:GetPlayers()) do
	trackPlayer(plr)
end
Players.PlayerAdded:Connect(function(plr)
	trackPlayer(plr)
end)
Players.PlayerRemoving:Connect(function(plr)
	untrackPlayer(plr)
end)

local humanoidConnections = {}

local function disconnectHumanoidConnections()
	for _, conn in ipairs(humanoidConnections) do
		conn:Disconnect()
	end
	table.clear(humanoidConnections)
end

local lastHealth, lastFloor, lastState, lastMove

local function connectHumanoidEvents()
	disconnectHumanoidConnections()
	if not humanoid then return end

	local hum = humanoid
	lastHealth = hum.Health
	lastFloor = hum.FloorMaterial
	lastState = hum:GetState()
	lastMove = hum.MoveDirection.Magnitude > 0

	local c1 = hum.HealthChanged:Connect(function(newHealth)
		if newHealth < lastHealth then
			Entity.OnDamaged:Fire(lastHealth - newHealth)
		end
		lastHealth = newHealth
	end)
	local c2 = hum.StateChanged:Connect(function(_, newState)
		Entity.OnStateChanged:Fire(newState)
		if newState == Enum.HumanoidStateType.Jumping then
			Entity.OnJump:Fire()
		end
		lastState = newState
	end)
	local c3 = hum.Running:Connect(function()
		local moving = hum.MoveDirection.Magnitude > 0
		if moving ~= lastMove then
			Entity.OnMoving:Fire(moving)
			lastMove = moving
		end
	end)
	local c4 = hum:GetPropertyChangedSignal("FloorMaterial"):Connect(function()
		local grounded = hum.FloorMaterial ~= Enum.Material.Air
		if grounded ~= (lastFloor ~= Enum.Material.Air) then
			Entity.OnGrounded:Fire(grounded)
			lastFloor = hum.FloorMaterial
		end
	end)

	table.insert(humanoidConnections, c1)
	table.insert(humanoidConnections, c2)
	table.insert(humanoidConnections, c3)
	table.insert(humanoidConnections, c4)
end

local function detectRig(char)
	if char:FindFirstChild("UpperTorso") then return "R15" end
	if char:FindFirstChild("Torso") then return "R6" end
	return "Unknown"
end

local function refresh(newChar)
	disconnectHumanoidConnections()

	character = newChar or nil
	if character then
		humanoid = character:FindFirstChild("Humanoid")
		rootPart = character:FindFirstChild("HumanoidRootPart")
		head = character:FindFirstChild("Head")
		rigType = detectRig(character)
		isAlive = character.Parent and rootPart and humanoid and humanoid.Parent and humanoid.Health > 0
		connectHumanoidEvents()
		Entity.CharacterAdded:Fire(character)
	else
		humanoid, rootPart, head, rigType, isAlive = nil, nil, nil, nil, false
		Entity.OnDied:Fire()
	end
end

player.CharacterAdded:Connect(refresh)
player.CharacterRemoving:Connect(function()
	Entity.CharacterRemoving:Fire(character)
	refresh(nil)
end)

if player.Character then
	refresh(player.Character)
end

RunService.Heartbeat:Connect(function()
	if humanoid then
		if not isAlive and humanoid.Health > 0 then
			isAlive = true
		elseif isAlive and humanoid.Health <= 0 then
			isAlive = false
			Entity.OnDied:Fire()
		end
	end
end)

