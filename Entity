function Entity.GetRigType()
	return rigType
end

function Entity.IsTeammate(plr)
	return plr and player and plr.Team == player.Team
end

function Entity.IsEnemy(plr)
	return plr and player and not Entity.IsTeammate(plr)
end

function Entity.GetNearestPlayer(range, ignoreTeam)
	local nearest = nil
	local shortest = range or math.huge
	for other, char in pairs(otherCharacters) do
		if char and char.Parent and char:FindFirstChild("HumanoidRootPart") then
			if not (ignoreTeam and Entity.IsTeammate(other)) then
				local pos = char.HumanoidRootPart.Position
				local dist = (pos - (rootPart and rootPart.Position or Vector3.zero)).Magnitude
				if dist < shortest then
					shortest = dist
					nearest = other
				end
			end
		end
	end
	return nearest
end

function Entity.GetNearestCharacter(range, ignoreTeam)
	local nearest = nil
	local shortest = range or math.huge
	for other, char in pairs(otherCharacters) do
		if char and char.Parent and char:FindFirstChild("HumanoidRootPart") then
			if not (ignoreTeam and Entity.IsTeammate(other)) then
				local pos = char.HumanoidRootPart.Position
				local dist = (pos - (rootPart and rootPart.Position or Vector3.zero)).Magnitude
				if dist < shortest then
					shortest = dist
					nearest = char
				end
			end
		end
	end
	return nearest
end

function Entity.GetNearestHumanoid(range, ignoreTeam)
	local char = Entity.GetNearestCharacter(range, ignoreTeam)
	return char and char:FindFirstChild("Humanoid") or nil
end

function Entity.GetNearestRootPart(range, ignoreTeam)
	local char = Entity.GetNearestCharacter(range, ignoreTeam)
	return char and char:FindFirstChild("HumanoidRootPart") or nil
end

function Entity.HasForceField()
	return character and character:FindFirstChildOfClass("ForceField") ~= nil
end

function Entity.IsInvulnerable()
	return Entity.HasForceField() or (humanoid and humanoid.Health <= 0)
end

function Entity.IsTargetable(plr)
	if not plr or plr == player then return false end
	local char = otherCharacters[plr] or (plr.Character and plr.Character.Parent and plr.Character)
	if not char then return false end
	local hum = char:FindFirstChild("Humanoid")
	if not hum or hum.Health <= 0 then return false end
	if char:FindFirstChildOfClass("ForceField") then return false end
	return true
end

function Entity.CanBeHit(plr)
	return Entity.IsTargetable(plr)
end

function Entity.WorldToViewport(point)
	local cam = Workspace.CurrentCamera
	return cam:WorldToViewportPoint(point)
end

function Entity.IsOnScreen()
	if not head then return false end
	local _, visible = Workspace.CurrentCamera:WorldToViewportPoint(head.Position)
	return visible
end

function Entity.CreateConnectionManager()
	local connections = {}
	local manager = {}
	function manager:Add(connection)
		table.insert(connections, connection)
	end
	function manager:Clean()
		for _, conn in ipairs(connections) do
			conn:Disconnect()
		end
		table.clear(connections)
	end
	return manager
end

function Entity.GetOtherPlayers()
	local list = {}
	for other, _ in pairs(otherCharacters) do
		table.insert(list, other)
	end
	return list
end

function Entity.GetOtherCharacters()
	local list = {}
	for _, char in pairs(otherCharacters) do
		if char and char.Parent then
			table.insert(list, char)
		end
	end
	return list
end

return Entity
